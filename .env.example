# SmartHome Backend — Variables d'environnement
# Copie ce fichier en .env et remplis tes vraies valeurs
# NE JAMAIS committer le .env dans Git !

# Clés API Tuya (depuis https://iot.tuya.com)
TUYA_CLIENT_ID=REMPLACE_PAR_TON_CLIENT_ID
TUYA_SECRET=REMPLACE_PAR_TON_SECRET_KEY

# Région du serveur Tuya : eu | us | cn | in
TUYA_REGION=eu

# URL de ton frontend (pour CORS)
# Ex: https://tonpseudo.github.io ou http://localhost:8080
FRONTEND_URL=https://tonpseudo.github.io

# Port du serveur backend
PORT=3000
